# Frontend
VITE_API_BASE_URL=http://127.0.0.1:4100
VITE_ENABLE_DEMO_LOGIN=1

# Backend
API_HOST=127.0.0.1
API_PORT=4100
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h
AUTH_REFRESH_EXPIRES_DAYS=30
AUTH_PASSWORD_RESET_EXPIRES_MINUTES=30
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:4173
ENABLE_DEMO_USERS=true
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Payment integrations (ifthenpay)
IFTHENPAY_API_KEY=
IFTHENPAY_MULTIBANCO_ENTITY=
IFTHENPAY_MULTIBANCO_SUBENTITY=
IFTHENPAY_MBWAY_KEY=
IFTHENPAY_ANTI_PHISHING_KEY=

# SEPA Direct Debit
SEPA_CREDITOR_IBAN=
SEPA_CREDITOR_BIC=
SEPA_CREDITOR_ID=

# Email (SMTP) - leave empty for console logging in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@condoos.pt
