{
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "backend/**,data/synthetic/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
